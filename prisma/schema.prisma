// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}



enum UserRole {
  ADMIN
}

enum ServiceCategory {
  MAIN_SERVICE
  YOUTH_SERVICE
  WOMEN_SERVICE
  MEN_SERVICE
  PRAYER_MEETING
  CELL_GROUP
  OTHER
}

enum AnnouncementCategory {
  GENERAL
  EVENT
  MINISTRY
  URGENT
}

enum Gender {
  MALE
  FEMALE
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  role        UserRole  @default(ADMIN)
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  announcements  Announcement[]
  devotionals    Devotional[]
  churchServices ChurchService[] @relation("ServiceCreatedBy")
  events         Event[]
  sessions Session[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(references: [id], fields: [userId], onDelete: Cascade)
}


model ChurchProfile {
  id                String   @id @default(cuid())

  churchName        String
  shortDescription  String?  @db.Text

  vision            String   @db.Text
  mission           String   @db.Text

  history           String   @db.Text
  background        String?  @db.Text

  address           String   @db.Text
  googleMapsLink    String?

  phoneNumber       String?
  whatsappNumber    String?

  email             String?

  instagramUrl      String?
  youtubeUrl        String?
  facebookUrl       String?
  websiteUrl        String?

  logoUrl           String?
  bannerUrl         String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  galleries         Gallery[]
}

model Gallery {
  id                String   @id @default(cuid())

  title             String
  imageUrl          String

  description       String?  @db.Text

  createdAt         DateTime @default(now())

  //
  // RELATION
  //

  churchProfileId   String

  churchProfile     ChurchProfile @relation(fields: [churchProfileId], references: [id], onDelete: Cascade)
}


//

// PENDETA
//

model Preacher {
  id            String   @id @default(cuid())

  fullName      String
  nickname      String?

  photoUrl      String?

  gender        Gender?

  birthDate     DateTime?

  phoneNumber   String?
  email         String?

  address       String?  @db.Text

  churchOrigin  String?
  position      String? // Pendeta, Penatua, Evangelis, dll

  biography     String? @db.Text

  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  //
  // RELATION
  //

  churchServices ChurchService[]
}

//
// KEBAKTIAN / IBADAH
//


model ChurchService {
  id                String   @id @default(cuid())

  title             String

  category          ServiceCategory @default(MAIN_SERVICE)

  serviceDate       DateTime

  startTime         DateTime
  endTime           DateTime

  theme             String

  preacherId String

  worshipLeader     String?

  description       String?  @db.Text

  additionalNotes   String?  @db.Text

  //
  // LIVE STREAM
  //

  liveYoutubeUrl    String?

  //
  // WARTA JEMAAT (PDF CLOUDINARY)
  //

  bulletinTitle     String?
  bulletinUrl       String?

  //
  // LITURGI (PDF CLOUDINARY)
  //

  liturgyTitle      String?
  liturgyUrl        String?

  //
  // STATUS
  //

  isPublished       Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  //
  // RELATION
  //

  createdById       String

  createdBy         User @relation("ServiceCreatedBy", fields: [createdById], references: [id])
  preacher   Preacher @relation(fields: [preacherId], references: [id])
}

//
// RENUNGAN HARIAN
//

model Devotional {
  id                String   @id @default(cuid())

  title             String

  slug              String   @unique

  bibleVerse        String?

  content           String   @db.Text

  //
  // YOUTUBE
  //

  youtubeUrl        String?

  thumbnailUrl      String?

  //
  // PUBLISH
  //

  isPublished       Boolean  @default(true)

  publishedAt       DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  //
  // RELATION
  //

  authorId          String

  author            User @relation(fields: [authorId], references: [id])
}

//
// PENGUMUMAN
//

model Announcement {
  id                String   @id @default(cuid())

  title             String

  slug              String   @unique

  content           String   @db.Text

  category          AnnouncementCategory @default(GENERAL)

  thumbnailUrl      String?

  isPublished       Boolean  @default(true)

  publishedAt       DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  //
  // RELATION
  //

  authorId          String

  author            User @relation(fields: [authorId], references: [id])
}

//
// EVENT GEREJA
//

model Event {
  id                String   @id @default(cuid())

  title             String

  slug              String   @unique

  description       String   @db.Text

  thumbnailUrl      String?

  location          String?

  startDate         DateTime
  endDate           DateTime?

  registrationLink  String?

  isPublished       Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  //
  // RELATION
  //

  createdById       String

  createdBy         User @relation(fields: [createdById], references: [id])
}

//
// DATA JEMAAT
//

model CongregationMember {
  id                  String   @id @default(cuid())

  fullName            String

  gender              Gender

  placeOfBirth        String?

  dateOfBirth         DateTime?

  phoneNumber         String?

  email               String?

  address             String?  @db.Text

  occupation          String?

  photoUrl            String?

  //
  // STATUS JEMAAT
  //

  baptismStatus       Boolean   @default(false)

  membershipStatus    Boolean   @default(true)

  notes               String?   @db.Text

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}
